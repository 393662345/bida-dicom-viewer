{
    "compilerOptions": {
      "target": "es5", // 编译目标 ES 版本，适配旧项目
      "module": "esnext", // 模块系统
      "moduleResolution": "node", // 模块解析方式
      "strict": true, // 开启严格模式（推荐，TS 核心特性）
      "jsx": "preserve", // 保留 JSX 交给 vue-loader 处理
      "sourceMap": true, // 生成 sourceMap 方便调试
      "resolveJsonModule": true, // 支持导入 json 文件
      "esModuleInterop": true, // 兼容 CommonJS/ES 模块
      "allowSyntheticDefaultImports": true, // 允许默认导入
      "lib": ["esnext", "dom"], // 依赖的 ES 库和 DOM 库
      "types": ["vue", "vue-router", "jquery", "node"], // 全局类型声明
      "baseUrl": ".", // 基础路径
      "paths": {
        "@/*": ["src/*"] // 适配 Vue 项目常用的 @ 别名（需和 Webpack 别名一致）
      },
      "skipLibCheck": true // 跳过第三方库的类型检查（避免 iview 等旧库类型报错）
    },
    "include": [
      "src/**/*.ts", 
      "src/**/*.tsx", 
      "src/**/*.vue", 
      "typings/**/*.d.ts" // 自定义类型声明文件
    ],
    "exclude": [
      "node_modules", 
      "build", 
      "dist"
    ]
  }